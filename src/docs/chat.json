{
  "openapi": "3.0.0",
  "info": {
    "title": "Chat Service API",
    "version": "1.0.0"
  },
  "paths": {
    "/chat/new": {
      "post": {
        "summary": "Tạo cuộc trò chuyện mới",
        "tags": ["CHAT"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "otherUserId": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hoàn thành"
          }
        }
      }
    },
    "/chat/all": {
      "get": {
        "summary": "Lấy danh sách tất cả trò chuyện",
        "tags": ["CHAT"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Hoàn thành"
          }
        }
      }
    },
    "/message": {
      "post": {
        "summary": "Gửi tin nhắn mới (chứa text hoặc file ảnh)",
        "tags": ["CHAT"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "chatId": {
                    "type": "string"
                  },
                  "text": {
                    "type": "string"
                  },
                  "image": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Gửi thành công"
          }
        }
      }
    },
    "/message/{chatId}": {
      "get": {
        "summary": "Lấy danh sách tin nhắn theo ID cuộc trò chuyện",
        "tags": ["CHAT"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "chatId",
            "in": "path",
            "required": true,
            "description": "ID của cuộc trò chuyện",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  }
}
