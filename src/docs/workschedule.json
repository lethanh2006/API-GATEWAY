{
  "openapi": "3.0.0",
  "info": {
    "title": "Workschedule Service API",
    "version": "1.0.0",
    "description": "API quản lý lịch làm việc tuần, đăng ký remote/leave/office, chấm công qua QR và quản lý chính sách đăng ký lịch của nhân viên."
  },
  "paths": {
    "/schedule/pending": {
      "get": {
        "summary": "Lấy danh sách yêu cầu đang chờ duyệt (Admin)",
        "description": "Lấy toàn bộ các yêu cầu đăng ký lịch làm việc có trạng thái là `pending` để admin phê duyệt. Có thể lọc theo tuần.",
        "tags": ["ADMIN SCHEDULE"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "week",
            "required": false,
            "description": "Tuần theo định dạng ISO week (ví dụ: 2026-W17)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lấy danh sách thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "count": { "type": "integer", "example": 1 },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ScheduleWithDetails"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "403": {
            "description": "Không có quyền truy cập (yêu cầu quyền schedule:read-all)"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/schedule/all": {
      "get": {
        "summary": "Lấy toàn bộ yêu cầu lịch làm việc (Admin)",
        "description": "Lấy tất cả yêu cầu lịch làm việc (ngoại trừ trạng thái `draft`). Có thể lọc theo tuần và trạng thái cụ thể.",
        "tags": ["ADMIN SCHEDULE"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "week",
            "required": false,
            "description": "Tuần theo định dạng ISO week (ví dụ: 2026-W17)",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "status",
            "required": false,
            "description": "Trạng thái yêu cầu để lọc. Nếu không truyền, mặc định sẽ lấy tất cả trạng thái khác `draft`.",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "pending",
                "approved",
                "rejected"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lấy danh sách thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "count": { "type": "integer", "example": 1 },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ScheduleWithDetails"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "403": {
            "description": "Không có quyền truy cập (yêu cầu quyền schedule:read-all)"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/schedule/requests/{id}/approve": {
      "post": {
        "summary": "Duyệt một yêu cầu lịch làm việc (Admin)",
        "description": "Duyệt yêu cầu lịch làm việc đang ở trạng thái `pending`. Nếu yêu cầu có lịch làm việc từ xa (`remote`), hệ thống sẽ tự động tạo bản ghi chấm công (`AttendanceRecord`) trước cho những ngày đó.",
        "tags": ["ADMIN SCHEDULE"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "description": "ID của yêu cầu lịch làm việc cần duyệt",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Duyệt thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Approved successfully" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Yêu cầu không hợp lệ hoặc yêu cầu không ở trạng thái pending"
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "403": {
            "description": "Không có quyền truy cập (yêu cầu quyền schedule:approve)"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/schedule/requests/{id}/reject": {
      "post": {
        "summary": "Từ chối một yêu cầu lịch làm việc (Admin)",
        "description": "Từ chối yêu cầu lịch làm việc đang ở trạng thái `pending` kèm theo lý do từ chối.",
        "tags": ["ADMIN SCHEDULE"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "description": "ID của yêu cầu lịch làm việc cần từ chối",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reason"],
                "properties": {
                  "reason": {
                    "type": "string",
                    "description": "Lý do từ chối yêu cầu",
                    "example": "Lịch đăng ký remote quá nhiều ngày mà không có lý do hợp lý."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Từ chối thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Rejected successfully" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Yêu cầu không hợp lệ hoặc yêu cầu không ở trạng thái pending"
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "403": {
            "description": "Không có quyền truy cập (yêu cầu quyền schedule:approve)"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/schedule/requests/bulk-approve": {
      "post": {
        "summary": "Duyệt hàng loạt các yêu cầu (Admin)",
        "description": "Duyệt đồng thời nhiều yêu cầu lịch làm việc ở trạng thái `pending` thông qua mảng chứa các IDs.",
        "tags": ["ADMIN SCHEDULE"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "ids"
                ],
                "properties": {
                  "ids": {
                    "type": "array",
                    "description": "Danh sách các ID yêu cầu cần duyệt",
                    "items": {
                      "type": "string"
                    },
                    "example": ["65f12a3b...", "65f12b4c..."]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Duyệt hàng loạt thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Bulk approval complete" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Thiếu danh sách ids hoặc danh sách không hợp lệ"
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "403": {
            "description": "Không có quyền truy cập (yêu cầu quyền schedule:approve)"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/schedule/heatmap": {
      "get": {
        "summary": "Thống kê heatmap theo tuần đã duyệt (Admin/User)",
        "description": "Thống kê số lượng nhân sự đăng ký theo từng hình thức (office, remote, day_off, leave) trong tuần để phục vụ vẽ biểu đồ nhiệt (heatmap).",
        "tags": ["ADMIN SCHEDULE"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "week",
            "required": false,
            "description": "Tuần cần thống kê theo định dạng ISO week (mặc định là tuần hiện tại)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lấy dữ liệu heatmap thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "_id": {
                            "type": "string",
                            "format": "date",
                            "description": "Ngày trong tuần",
                            "example": "2026-04-20T00:00:00.000Z"
                          },
                          "stats": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "type": {
                                  "type": "string",
                                  "enum": ["office", "remote", "day_off", "leave"]
                                },
                                "count": {
                                  "type": "integer",
                                  "description": "Số lượng nhân sự đăng ký"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "403": {
            "description": "Không có quyền truy cập"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/attendance/scan": {
      "post": {
        "summary": "Quét token QR để check-in hoặc check-out (User)",
        "description": "Sử dụng token QR hợp lệ (từ Admin cung cấp) để ghi nhận check-in hoặc check-out cho ngày hôm đó. Người dùng phải có lịch làm việc tại văn phòng (`office`) được duyệt cho ngày hiện tại.",
        "tags": ["ATTENDANCE"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token"],
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "Chuỗi token QR Code được quét",
                    "example": "2f8a84bc5a..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ghi nhận check-in hoặc check-out thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Check-in thành công" },
                    "data": {
                      "$ref": "#/components/schemas/AttendanceRecord"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Token không hợp lệ, đã sử dụng, hết hạn hoặc người dùng không có lịch office được duyệt hôm nay."
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/attendance/my": {
      "get": {
        "summary": "Lấy lịch sử chấm công của tôi (User)",
        "description": "Truy vấn danh sách các lần chấm công cá nhân của người dùng hiện tại, hỗ trợ khoảng thời gian từ ngày nào đến ngày nào.",
        "tags": ["ATTENDANCE"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "from",
            "required": false,
            "description": "Từ ngày (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "in": "query",
            "name": "to",
            "required": false,
            "description": "Đến ngày (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lấy dữ liệu thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "count": { "type": "integer", "example": 5 },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AttendanceRecordWithEmployee"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/attendance/qr/generate": {
      "post": {
        "summary": "Tạo token QR chấm công mới (Admin)",
        "description": "Tạo một token QR ngẫu nhiên dùng để chấm công, token có giá trị sử dụng trong vòng 30 giây.",
        "tags": ["ATTENDANCE"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "Tạo token thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "$ref": "#/components/schemas/AttendanceQrToken"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "403": {
            "description": "Không có quyền truy cập (yêu cầu quyền attendance:generate)"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/attendance/today": {
      "get": {
        "summary": "Lấy danh sách nhân viên chấm công trong ngày (Admin)",
        "description": "Lấy tất cả các bản ghi chấm công có lượt check-in trong ngày hôm nay.",
        "tags": ["ATTENDANCE"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lấy dữ liệu thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "count": { "type": "integer", "example": 2 },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AttendanceRecordWithEmployee"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "403": {
            "description": "Không có quyền truy cập"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/attendance/report": {
      "get": {
        "summary": "Lấy báo cáo chấm công toàn công ty (Admin)",
        "description": "Lấy báo cáo chấm công của toàn bộ nhân viên hoặc lọc theo từng nhân viên trong khoảng thời gian xác định.",
        "tags": ["ATTENDANCE"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "from",
            "required": false,
            "description": "Từ ngày (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "in": "query",
            "name": "to",
            "required": false,
            "description": "Đến ngày (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "in": "query",
            "name": "employee_id",
            "required": false,
            "description": "ID của nhân viên cụ thể cần lọc",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lấy báo cáo thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "count": { "type": "integer", "example": 10 },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AttendanceRecordWithEmployee"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "403": {
            "description": "Không có quyền truy cập"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/policy": {
      "get": {
        "summary": "Xem chính sách đăng ký lịch làm việc hiện tại",
        "description": "Lấy cấu hình khoảng thời gian bắt đầu/kết thúc đăng ký và trạng thái khóa của hệ thống đăng ký lịch.",
        "tags": ["POLICY"],
        "responses": {
          "200": {
            "description": "Lấy policy thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "count": { "type": "integer", "example": 1 },
                    "data": {
                      "$ref": "#/components/schemas/WorkPolicy"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      },
      "patch": {
        "summary": "Cập nhật chính sách đăng ký lịch làm việc (Admin)",
        "description": "Cập nhật thời hạn mở/đóng đăng ký lịch tuần và mở/khóa hệ thống đăng ký lịch làm việc của nhân viên.",
        "tags": ["POLICY"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "registration_start": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Thời gian bắt đầu cho phép đăng ký lịch",
                    "example": "2026-04-01T08:00:00.000Z"
                  },
                  "registration_end": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Thời gian hết hạn đăng ký lịch",
                    "example": "2026-04-07T18:00:00.000Z"
                  },
                  "locked": {
                    "type": "boolean",
                    "description": "Khóa/mở chức năng đăng ký",
                    "example": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cập nhật chính sách thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "$ref": "#/components/schemas/WorkPolicy"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "403": {
            "description": "Không có quyền truy cập"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
    "/schedule/my": {
      "get": {
        "summary": "Lấy danh sách lịch làm việc của tôi (User)",
