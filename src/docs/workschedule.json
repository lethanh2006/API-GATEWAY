    "/schedule/requests": {
      "post": {
        "summary": "Khởi tạo yêu cầu đăng ký lịch làm việc mới (User)",
        "description": "Tạo một yêu cầu lịch làm việc nháp (`draft`) cho một tuần nhất định kèm theo các ngày cụ thể. Ngày bắt đầu tuần (`week_start`) bắt buộc phải là thứ Hai. Việc tạo mới bị giới hạn bởi thời gian mở đăng ký của Policy và tối đa 4 tuần tới (nếu không phải là Admin).",
        "tags": ["SCHEDULE REQUEST"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "week_start"
                ],
                "properties": {
                  "week_start": {
                    "type": "string",
                    "format": "date",
                    "description": "Ngày bắt đầu tuần (yêu cầu là thứ Hai - YYYY-MM-DD)",
                    "example": "2026-04-20"
                  },
                  "entries": {
                    "type": "array",
                    "description": "Danh sách lịch làm việc của từng ngày trong tuần",
                    "items": {
                      "type": "object",
                      "required": ["date", "type"],
                      "properties": {
                        "date": {
                          "type": "string",
                          "format": "date",
                          "description": "Ngày cụ thể",
                          "example": "2026-04-20"
                        },
                        "type": {
                          "type": "string",
                          "enum": [
                            "office",
                            "remote",
                            "day_off",
                            "leave"
                          ],
                          "description": "Hình thức làm việc/nghỉ",
                          "example": "office"
                        },
                        "note": {
                          "type": "string",
                          "description": "Ghi chú thêm",
                          "example": "Lên văn phòng họp nhóm"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tạo yêu cầu thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "$ref": "#/components/schemas/ScheduleRequest"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Dữ liệu không hợp lệ, week_start không phải thứ 2, đã tồn tại lịch đăng ký cho tuần này hoặc bị hạn chế bởi Policy/Giới hạn 4 tuần tương lai."
          },
          "401": {
            "description": "Chưa xác thực"
          },
          "500": {
            "description": "Lỗi máy chủ nội bộ"
          }
        }
      }
    },
