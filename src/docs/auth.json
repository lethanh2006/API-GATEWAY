{
  "openapi": "3.0.0",
  "info": {
    "title": "Auth Service API",
    "version": "1.0.0"
  },
  "paths": {
    "/register": {
      "post": {
        "summary": "Đăng ký tài khoản người dùng mới",
        "tags": ["AUTH"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password",
                  "username"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email người dùng"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 6,
                    "description": "Mật khẩu (tối thiểu 6 ký tự)"
                  },
                  "username": {
                    "type": "string",
                    "description": "Tên hiển thị người dùng"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Đăng ký thành công"
          },
          "400": {
            "description": "Yêu cầu không hợp lệ hoặc email đã tồn tại"
          }
        }
      }
    },
    "/login": {
      "post": {
        "summary": "Đăng nhập bằng email và mật khẩu (yêu cầu gửi OTP)",
        "tags": ["AUTH"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email người dùng"
                  },
                  "password": {
                    "type": "string",
                    "description": "Mật khẩu người dùng"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP đã được gửi thành công"
          },
          "400": {
            "description": "Thông tin đăng nhập không hợp lệ"
          },
          "429": {
            "description": "Gửi OTP quá nhanh (rate limited)"
          }
        }
      }
    },
    "/verify": {
      "post": {
        "summary": "Xác nhận OTP để hoàn tất đăng nhập và nhận JWT token",
        "tags": ["AUTH"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "otp"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email đăng ký"
                  },
                  "otp": {
                    "type": "string",
                    "minLength": 6,
                    "maxLength": 6,
                    "description": "Mã OTP 6 số nhận từ email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Xác thực thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "token": {
                      "type": "string"
                    },
                    "user": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Mã OTP không hợp lệ hoặc đã hết hạn"
          }
        }
      }
    }
  }
}
