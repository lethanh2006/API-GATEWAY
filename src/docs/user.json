{
  "openapi": "3.0.0",
  "info": {
    "title": "User Service API",
    "version": "1.0.0"
  },
  "paths": {
    "/me": {
      "get": {
        "summary": "Lấy thông tin profile người dùng hiện tại",
        "tags": ["USER"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Thông tin profile của người dùng"
          },
          "401": {
            "description": "Không có quyền truy cập"
          }
        }
      }
    },
    "/user/all": {
      "get": {
        "summary": "Lấy danh sách tất cả người dùng trong hệ thống",
        "tags": ["USER"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Danh sách người dùng"
          },
          "401": {
            "description": "Không có quyền truy cập"
          }
        }
      }
    },
    "/user/{id}": {
      "get": {
        "summary": "Lấy thông tin profile người dùng theo ID",
        "tags": ["USER"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID người dùng cần lấy profile",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Thông tin profile người dùng"
          },
          "401": {
            "description": "Không có quyền truy cập"
          },
          "404": {
            "description": "Không tìm thấy người dùng"
          }
        }
      }
    },
    "/update/user": {
      "post": {
        "summary": "Cập nhật tên người dùng",
        "tags": ["USER"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username"],
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "Tên người dùng mới"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cập nhật tên thành công"
          },
          "401": {
            "description": "Không có quyền truy cập"
          }
        }
      }
    }
  }
}
